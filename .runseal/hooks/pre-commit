#!/usr/bin/env sh
# santi :init hook: generated by runseal :init
set -eu
root=$(git rev-parse --show-toplevel)
cd "$root"

branch=$(git symbolic-ref --quiet --short HEAD || true)
if [ "$branch" = "main" ]; then
  printf '%s\n' "pre-commit: refusing to commit directly on main" >&2
  printf '%s\n' "create a feature branch first, then commit again" >&2
  exit 1
fi

runseal :guard
